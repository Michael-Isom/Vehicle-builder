{
  "compilerOptions": {
    /* Output Options */
    "outDir": "./dist",                            /* Output folder for emitted files. */
    "rootDir": "./src",                            /* Root directory of source files. */

    /* Language and Environment */
    "target": "ES2020",                            /* Set the JavaScript language version for emitted JavaScript. */
    "module": "ESNext",                            /* Specify the module code generation for ES Modules. */
    "moduleResolution": "node",                    /* Use Node.js-style module resolution. */
    
    /* Strict Type-Checking Options */
    "strict": true,                                /* Enable all strict type-checking options. */
    "noImplicitAny": true,                         /* Disallow variables of type 'any'. */
    "strictNullChecks": true,                      /* Enable strict null checks. */
    "strictFunctionTypes": true,                   /* Ensure functions have matching parameter types. */
    "strictBindCallApply": true,                   /* Ensure parameters are compatible with 'bind', 'call', and 'apply'. */
    "strictPropertyInitialization": true,          /* Check class property initialization. */
    "noImplicitThis": true,                        /* Report errors when 'this' is implicitly 'any'. */
    "exactOptionalPropertyTypes": true,            /* Preserve the type of optional properties exactly as written. */
    "noImplicitReturns": true,                     /* Report errors for functions without an explicit return. */
    "noImplicitOverride": true,                    /* Ensure overridden methods are marked with the override modifier. */

    /* Compatibility Options */
    "esModuleInterop": true,                       /* Enables compatibility with CommonJS modules. */
    "skipLibCheck": true,                          /* Skip type checking of declaration files. */
    "forceConsistentCasingInFileNames": true,      /* Ensure correct casing in file imports. */
    
    /* JavaScript Support */
    "allowJs": true,                               /* Allow JavaScript files to be part of the program. */
    "checkJs": false,                              /* Disable type-checking for JavaScript files. */

    /* Emit Options */
    "noEmitOnError": true,                         /* Do not emit output if there are type errors. */
    
    /* Paths and Extensions */
    "resolveJsonModule": true,                     /* Allow importing .json files. */
    "allowSyntheticDefaultImports": true           /* Allow default imports from modules with no default export. */
  },
  "include": [
    "src/**/*"                                     /* Include all files within the src directory. */
  ],
  "exclude": [
    "node_modules",                                /* Exclude the node_modules folder. */
    "**/*.spec.ts"                                 /* Exclude all test files. */
  ]
}